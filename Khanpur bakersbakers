// CART
let cart = [];

// RENDER MENU
function renderMenu(filter='all'){
  const grid = document.getElementById('menuGrid');
  const items = filter==='all'? menuItems : menuItems.filter(i=>i.cat===filter);
  grid.innerHTML = items.map((item,idx)=>`
    <div class="menu-card" style="animation:fadeInUp .5s ${idx*0.04}s both;">
      ${item.popular?'<div class="popular-badge">⭐ Popular</div>':''}
      <div class="menu-card-img">
        <img src="${item.img}" alt="${item.name}" loading="lazy" onerror="this.parentElement.innerHTML='<div style=\'width:100%;height:100%;background:linear-gradient(135deg,#F5E4B8,#C8952A);display:flex;align-items:center;justify-content:center;font-size:5rem;\'>'+encodeURIComponent('${item.emoji}')+'</div>'">
        <div class="img-overlay"></div>
      </div>
      <div class="menu-card-body">
        <div class="menu-card-tag">${item.tag}</div>
        <div class="menu-card-name">${item.name}</div>
        <div class="menu-card-desc">${item.desc}</div>
        <div class="menu-card-footer">
          <div class="menu-price">PKR ${item.price.toLocaleString()} <span>/unit</span></div>
          <button class="btn-add" onclick='addToCart(${JSON.stringify({name:item.name,price:item.price,emoji:item.emoji,img:item.img})})' title="Add to cart">+</button>
        </div>
      </div>
    </div>
  `).join('');
}

function filterMenu(btn, cat){
  document.querySelectorAll('.menu-tab').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  renderMenu(cat);
}
renderMenu();

// CART LOGIC
function addToCart(item){
  const existing = cart.find(c=>c.name===item.name);
  if(existing) existing.qty++;
  else cart.push({...item, qty:1});
  updateCartUI();
  showToast(`✅ ${item.emoji} ${item.name} added!`);
}

function updateCartUI(){
  const count = cart.reduce((s,i)=>s+i.qty,0);
  document.getElementById('cartCount').textContent = count;
  document.getElementById('cartCountLabel').textContent = count+' item'+(count!==1?'s':'');
  const sub = cart.reduce((s,i)=>s+i.price*i.qty,0);

  const makeItemsHTML = ()=> cart.length===0
    ? `<div class="cart-empty"><div class="cart-empty-icon">🛒</div><p>Your cart is empty.<br>Add items from the menu!</p></div>`
    : cart.map((item,i)=>`
        <div class="cart-item">
          <div class="cart-item-thumb">
            <img src="${item.img}" alt="${item.name}" onerror="this.parentElement.innerHTML='<div class=\\'cart-item-thumb-emoji\\'>${item.emoji}</div>'">
          </div>
          <div class="cart-item-info">
            <div class="cart-item-name">${item.name}</div>
            <div class="cart-item-price">PKR ${(item.price*item.qty).toLocaleString()}</div>
          </div>
          <div class="cart-item-qty">
            <button class="qty-btn" onclick="changeQty(${i},-1)">−</button>
            <span class="qty-num">${item.qty}</span>
            <button class="qty-btn" onclick="changeQty(${i},1)">+</button>
          </div>
        </div>`).join('');

  const html = makeItemsHTML();
  document.getElementById('cartItems').innerHTML = html;
  document.getElementById('cartModalItems').innerHTML = html;

  const showTotal = cart.length>0;
  document.getElementById('cartTotalSection').style.display = showTotal?'block':'none';
  document.getElementById('cartModalTotal').style.display = showTotal?'block':'none';

  document.getElementById('sideCartSubtotal').textContent = 'PKR '+sub.toLocaleString();
  document.getElementById('sideCartTotal').textContent = 'PKR '+sub.toLocaleString();
  document.getElementById('cartSubtotal').textContent = 'PKR '+sub.toLocaleString();
  document.getElementById('cartGrandTotal').textContent = 'PKR '+sub.toLocaleString();
}

function changeQty(index, delta){
  cart[index].qty += delta;
  if(cart[index].qty<=0) cart.splice(index,1);
  updateCartUI();
}

function toggleCart(){ document.getElementById('cartModal').classList.toggle('open'); }
function closeCart(){ document.getElementById('cartModal').classList.remove('open'); }

function checkout(){
  if(!cart.length) return;
  const items = cart.map(i=>`${i.qty}x ${i.name} (PKR ${(i.price*i.qty).toLocaleString()})`).join('%0A');
  const total = cart.reduce((s,i)=>s+i.price*i.qty,0);
  const msg = `Hello Khanpur Bakers! I'd like to place an order:%0A%0A${items}%0A%0ADelivery: FREE%0ATotal: PKR ${total.toLocaleString()}`;
  window.open(`https://wa.me/923001234567?text=${msg}`,'_blank');
}

// ORDER FORM
function updateOrderPrice(){
  const sel = document.getElementById('oItem').value;
  const qty = parseInt(document.getElementById('oQty').value)||1;
  if(!sel){document.getElementById('orderPriceDisplay').style.display='none';return;}
  const price = parseInt(sel.split('|')[1]);
  const total = price*qty;
  document.getElementById('orderTotal').textContent = `PKR ${total.toLocaleString()}`;
  document.getElementById('orderPriceDisplay').style.display='block';
}

function submitOrder(){
  const name=document.getElementById('oName').value;
  const phone=document.getElementById('oPhone').value;
  const address=document.getElementById('oAddress').value;
  const item=document.getElementById('oItem').value;
  if(!name||!phone||!address||!item){showToast('⚠️ Please fill all required fields!');return;}
  document.getElementById('orderSuccess').style.display='block';
  setTimeout(()=>{document.getElementById('orderSuccess').style.display='none';},5000);
  const itemName=item.split('|')[0];
  const qty=document.getElementById('oQty').value;
  const msg=`New Order!%0AName: ${encodeURIComponent(name)}%0APhone: ${encodeURIComponent(phone)}%0AAddress: ${encodeURIComponent(address)}%0AItem: ${encodeURIComponent(itemName)} x${qty}%0ADelivery: FREE%0ANotes: ${encodeURIComponent(document.getElementById('oNotes').value)}`;
  window.open(`https://wa.me/923001234567?text=${msg}`,'_blank');
}

function sendMessage(){
  const name=document.getElementById('cName').value;
  const msg=document.getElementById('cMessage').value;
  if(!name||!msg){showToast('⚠️ Please fill in your name and message!');return;}
  document.getElementById('contactSuccess').style.display='block';
  setTimeout(()=>{document.getElementById('contactSuccess').style.display='none';},5000);
}

// TOAST
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3000);
}

// NAV SCROLL
window.addEventListener('scroll',()=>{
  const nav=document.getElementById('nav');
  nav.classList.toggle('scrolled',window.scrollY>50);
});

// MOBILE NAV
function openMobileNav(){document.getElementById('mobileNav').classList.add('open');}
function closeMobileNav(){document.getElementById('mobileNav').classList.remove('open');}

// REVEAL
const observer=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');});
},{threshold:.1});
document.querySelectorAll('.reveal').forEach(el=>observer.observe(el));

// LOADER
window.addEventListener('load',()=>{
  setTimeout(()=>{document.getElementById('loader').classList.add('hidden');},1800);
});

// MIN DATE
document.getElementById('oDate').min=new Date().toISOString().split('T')[0];
</script>
