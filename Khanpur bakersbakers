<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Khanpur Bakers — Artisan Bakery & Sweets</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --cream:#FDF8F0; --cream-dark:#F5EDD8; --gold:#C8952A; --gold-light:#E4B84A;
    --gold-pale:#F5E4B8; --brown:#3D1F0A; --brown-mid:#6B3A1F; --brown-light:#A0633A;
    --chocolate:#2C1206; --text-dark:#1A0D05; --text-mid:#5C3A1E; --text-light:#9A7A5A;
    --white:#FFFFFF; --shadow:rgba(61,31,10,.15); --shadow-deep:rgba(61,31,10,.30);
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;font-size:16px;}
  body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text-dark);overflow-x:hidden;}
  ::-webkit-scrollbar{width:6px;}
  ::-webkit-scrollbar-track{background:var(--cream-dark);}
  ::-webkit-scrollbar-thumb{background:var(--gold);border-radius:3px;}

  /* LOADER */
  #loader{position:fixed;inset:0;background:var(--chocolate);display:flex;align-items:center;justify-content:center;z-index:9999;transition:opacity .6s .2s,visibility .6s .2s;}
  #loader.hidden{opacity:0;visibility:hidden;}
  .loader-inner{text-align:center;}
  .loader-logo{font-family:'Playfair Display',serif;font-size:2.5rem;color:var(--gold);letter-spacing:4px;animation:pulse 1.5s ease-in-out infinite;}
  .loader-bar{width:200px;height:2px;background:rgba(255,255,255,.1);margin:20px auto 0;border-radius:2px;overflow:hidden;}
  .loader-bar-fill{height:100%;width:0;background:var(--gold);border-radius:2px;animation:loadFill 1.8s ease forwards;}
  @keyframes loadFill{to{width:100%;}}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}

  /* NAV */
  nav{position:fixed;top:0;width:100%;z-index:1000;padding:0 5%;display:flex;align-items:center;justify-content:space-between;height:75px;background:transparent;transition:background .4s,box-shadow .4s,height .4s;}
  nav.scrolled{background:rgba(253,248,240,.97);box-shadow:0 2px 30px var(--shadow);height:65px;backdrop-filter:blur(20px);}
  .nav-logo{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:900;color:var(--white);letter-spacing:2px;transition:color .4s;text-decoration:none;display:flex;align-items:center;gap:10px;}
  nav.scrolled .nav-logo{color:var(--brown);}
  .nav-links{display:flex;align-items:center;gap:35px;list-style:none;}
  .nav-links a{font-size:.85rem;font-weight:500;letter-spacing:1.5px;text-transform:uppercase;text-decoration:none;color:rgba(255,255,255,.9);transition:color .3s;position:relative;}
  nav.scrolled .nav-links a{color:var(--text-mid);}
  .nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1.5px;background:var(--gold);transition:width .3s;}
  .nav-links a:hover::after{width:100%;}
  .nav-links a:hover{color:var(--gold);}
  nav.scrolled .nav-links a:hover{color:var(--gold);}
  .nav-cart{background:var(--gold);color:var(--white);border:none;padding:10px 22px;border-radius:30px;font-size:.8rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;cursor:pointer;display:flex;align-items:center;gap:8px;transition:background .3s,transform .2s;}
  .nav-cart:hover{background:var(--gold-light);transform:translateY(-1px);}
  .cart-badge{background:var(--brown);color:var(--white);border-radius:50%;width:18px;height:18px;font-size:.7rem;display:flex;align-items:center;justify-content:center;font-weight:700;}
  .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:5px;}
  .hamburger span{display:block;width:24px;height:2px;background:var(--white);transition:all .3s;border-radius:2px;}
  nav.scrolled .hamburger span{background:var(--brown);}

  /* FREE DELIVERY ANNOUNCEMENT */
  .announcement-bar{background:linear-gradient(90deg,var(--brown),var(--brown-mid),var(--brown));color:var(--white);text-align:center;padding:10px;font-size:.82rem;letter-spacing:1px;font-weight:600;position:relative;overflow:hidden;}
  .announcement-bar::before{content:'🎉';margin-right:8px;}
  .announcement-bar::after{content:'🎉';margin-left:8px;}

  /* HERO */
  #hero{min-height:100vh;position:relative;display:flex;align-items:center;overflow:hidden;}
  .hero-bg{position:absolute;inset:0;background:linear-gradient(135deg,#1a0800 0%,#3D1F0A 40%,#6B3A1F 70%,#2C1206 100%);}
  .hero-pattern{position:absolute;inset:0;opacity:.04;background-image:repeating-linear-gradient(45deg,var(--gold) 0px,var(--gold) 1px,transparent 1px,transparent 40px),repeating-linear-gradient(-45deg,var(--gold) 0px,var(--gold) 1px,transparent 1px,transparent 40px);}
  .hero-glow{position:absolute;right:-100px;top:50%;transform:translateY(-50%);width:700px;height:700px;background:radial-gradient(circle,rgba(200,149,42,.25) 0%,transparent 70%);pointer-events:none;}
  .hero-content{position:relative;z-index:2;padding:120px 5% 80px;max-width:700px;}
  .hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(200,149,42,.15);border:1px solid rgba(200,149,42,.3);color:var(--gold-light);padding:8px 20px;border-radius:30px;font-size:.75rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;margin-bottom:28px;animation:fadeInUp .8s .3s both;}
  .hero-title{font-family:'Playfair Display',serif;font-size:clamp(3rem,6vw,5.5rem);font-weight:900;line-height:1.05;color:var(--white);margin-bottom:12px;animation:fadeInUp .8s .5s both;}
  .hero-title em{font-style:italic;color:var(--gold);display:block;}
  .hero-subtitle{font-family:'Cormorant Garamond',serif;font-size:clamp(1.1rem,2vw,1.4rem);color:rgba(255,255,255,.7);margin-bottom:20px;font-weight:300;line-height:1.7;animation:fadeInUp .8s .7s both;}
  .hero-free-delivery{display:inline-flex;align-items:center;gap:8px;background:rgba(37,211,102,.15);border:1px solid rgba(37,211,102,.3);color:#4ade80;padding:10px 20px;border-radius:30px;font-size:.85rem;font-weight:700;margin-bottom:30px;animation:fadeInUp .8s .8s both;}
  .hero-ctas{display:flex;gap:16px;flex-wrap:wrap;animation:fadeInUp .8s .9s both;}
  .btn-primary{background:linear-gradient(135deg,var(--gold),var(--gold-light));color:var(--white);border:none;padding:16px 36px;border-radius:50px;font-size:.9rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:10px;box-shadow:0 8px 30px rgba(200,149,42,.4);transition:transform .3s,box-shadow .3s;}
  .btn-primary:hover{transform:translateY(-3px);box-shadow:0 14px 40px rgba(200,149,42,.5);}
  .btn-outline{background:transparent;color:var(--white);border:1.5px solid rgba(255,255,255,.5);padding:16px 36px;border-radius:50px;font-size:.9rem;font-weight:500;letter-spacing:1px;text-transform:uppercase;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:10px;transition:background .3s,border-color .3s,transform .3s;}
  .btn-outline:hover{background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.8);transform:translateY(-3px);}
  .hero-stats{position:absolute;bottom:50px;right:5%;display:flex;gap:40px;animation:fadeInRight .8s 1.1s both;}
  .stat{text-align:center;}
  .stat-num{font-family:'Playfair Display',serif;font-size:2.4rem;font-weight:900;color:var(--gold);line-height:1;}
  .stat-label{font-size:.75rem;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:1.5px;margin-top:4px;}
  .hero-scroll{position:absolute;bottom:30px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;color:rgba(255,255,255,.5);font-size:.7rem;letter-spacing:2px;text-transform:uppercase;cursor:pointer;animation:bounce 2s infinite;}
  .scroll-line{width:1px;height:40px;background:linear-gradient(to bottom,var(--gold),transparent);}
  @keyframes bounce{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(6px)}}
  .hero-img-grid{position:absolute;right:3%;top:50%;transform:translateY(-50%);width:min(480px,42vw);display:grid;grid-template-columns:1fr 1fr;gap:14px;animation:fadeInRight .8s .6s both;}
  .hero-img-cell{border-radius:18px;overflow:hidden;aspect-ratio:1;box-shadow:0 15px 40px rgba(0,0,0,.5);}
  .hero-img-cell img{width:100%;height:100%;object-fit:cover;transition:transform .4s;}
  .hero-img-cell:hover img{transform:scale(1.05);}
  .hero-img-cell.tall{aspect-ratio:.75;}
  .hero-img-cell:nth-child(1){grid-row:span 2;aspect-ratio:auto;}

  /* SECTION */
  section{padding:100px 5%;}
  .section-label{font-size:.7rem;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:12px;display:flex;align-items:center;gap:12px;}
  .section-label::before,.section-label::after{content:'';flex:1;max-width:50px;height:1px;background:var(--gold);}
  .section-label.center{justify-content:center;text-align:center;}
  .section-title{font-family:'Playfair Display',serif;font-size:clamp(2rem,4vw,3.2rem);font-weight:700;line-height:1.2;color:var(--brown);margin-bottom:16px;}
  .section-title.light{color:var(--white);}
  .section-title.center{text-align:center;}
  .section-desc{font-family:'Cormorant Garamond',serif;font-size:1.2rem;color:var(--text-light);max-width:600px;line-height:1.8;}
  .section-desc.center{text-align:center;margin:0 auto;}

  /* FEATURES */
  #features{background:var(--brown);padding:50px 5%;}
  .features-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0;}
  .feature-item{display:flex;align-items:center;gap:16px;padding:0 30px;border-right:1px solid rgba(255,255,255,.1);}
  .feature-item:last-child{border-right:none;}
  .feature-icon{font-size:2rem;flex-shrink:0;}
  .feature-text h4{font-family:'Playfair Display',serif;color:var(--white);font-size:1rem;font-weight:600;margin-bottom:4px;}
  .feature-text p{color:rgba(255,255,255,.6);font-size:.82rem;}
  .feature-free-tag{background:var(--gold);color:var(--white);font-size:.65rem;padding:2px 8px;border-radius:10px;font-weight:700;margin-left:6px;}

  /* ABOUT */
  #about{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
  .about-visual{position:relative;height:550px;}
  .about-img-main{width:75%;height:420px;border-radius:20px;overflow:hidden;position:absolute;bottom:0;left:0;box-shadow:20px 20px 60px var(--shadow-deep);}
  .about-img-main img{width:100%;height:100%;object-fit:cover;}
  .about-img-accent{position:absolute;top:0;right:0;width:55%;height:280px;border-radius:20px;overflow:hidden;box-shadow:10px 10px 40px var(--shadow);}
  .about-img-accent img{width:100%;height:100%;object-fit:cover;}
  .about-badge{position:absolute;bottom:60px;right:-10px;background:var(--gold);color:var(--white);border-radius:16px;padding:16px 20px;text-align:center;box-shadow:0 10px 30px rgba(200,149,42,.4);z-index:2;}
  .about-badge-num{font-family:'Playfair Display',serif;font-size:2.2rem;font-weight:900;line-height:1;}
  .about-badge-text{font-size:.7rem;letter-spacing:1.5px;opacity:.9;margin-top:4px;}
  .about-list{list-style:none;margin:30px 0;display:grid;grid-template-columns:1fr 1fr;gap:12px;}
  .about-list li{display:flex;align-items:center;gap:10px;font-size:.9rem;color:var(--text-mid);}
  .about-list li::before{content:'✦';color:var(--gold);font-size:.7rem;flex-shrink:0;}

  /* MENU */
  #menu{background:var(--cream-dark);}
  .menu-tabs{display:flex;flex-wrap:wrap;gap:10px;justify-content:center;margin:40px 0;}
  .menu-tab{padding:10px 24px;border-radius:30px;border:1.5px solid var(--gold-pale);background:transparent;color:var(--text-mid);font-size:.82rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all .3s;}
  .menu-tab.active,.menu-tab:hover{background:var(--gold);border-color:var(--gold);color:var(--white);}
  .menu-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px;}
  .menu-card{background:var(--white);border-radius:20px;overflow:hidden;box-shadow:0 4px 20px var(--shadow);transition:transform .3s,box-shadow .3s;position:relative;}
  .menu-card:hover{transform:translateY(-6px);box-shadow:0 14px 40px var(--shadow-deep);}
  .menu-card-img{height:200px;overflow:hidden;position:relative;}
  .menu-card-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s;}
  .menu-card:hover .menu-card-img img{transform:scale(1.06);}
  .menu-card-img .img-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(61,31,10,.3) 0%,transparent 60%);}
  .menu-card-body{padding:20px;}
  .menu-card-tag{font-size:.65rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:6px;}
  .menu-card-name{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--brown);margin-bottom:8px;}
  .menu-card-desc{font-size:.82rem;color:var(--text-light);line-height:1.6;margin-bottom:16px;}
  .menu-card-footer{display:flex;align-items:center;justify-content:space-between;}
  .menu-price{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;color:var(--gold);}
  .menu-price span{font-size:.75rem;font-weight:400;color:var(--text-light);}
  .btn-add{background:var(--brown);color:var(--white);border:none;width:38px;height:38px;border-radius:50%;font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .3s,transform .2s;}
  .btn-add:hover{background:var(--gold);transform:scale(1.1);}
  .popular-badge{position:absolute;top:12px;right:12px;background:var(--gold);color:var(--white);font-size:.65rem;font-weight:700;letter-spacing:1px;padding:4px 10px;border-radius:20px;text-transform:uppercase;z-index:2;}

  /* GALLERY */
  #gallery{background:var(--brown);padding:100px 5%;}
  .gallery-grid{display:grid;grid-template-columns:repeat(4,1fr);grid-template-rows:repeat(3,220px);gap:14px;margin-top:50px;}
  .gallery-cell{border-radius:18px;overflow:hidden;cursor:pointer;transition:transform .3s;position:relative;}
  .gallery-cell:hover{transform:scale(1.02);}
  .gallery-cell img{width:100%;height:100%;object-fit:cover;transition:transform .4s;}
  .gallery-cell:hover img{transform:scale(1.07);}
  .gallery-cell.tall{grid-row:span 2;}
  .gallery-cell.wide{grid-column:span 2;}
  .gallery-cell-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.65) 0%,transparent 60%);opacity:0;transition:opacity .3s;display:flex;align-items:flex-end;padding:18px;}
  .gallery-cell:hover .gallery-cell-overlay{opacity:1;}
  .gallery-cell-label{font-family:'Playfair Display',serif;color:var(--white);font-size:1rem;font-weight:600;}

  /* SPECIALS */
  .specials-banner{background:linear-gradient(135deg,var(--gold) 0%,#E4B84A 50%,var(--gold) 100%);padding:60px 5%;display:grid;grid-template-columns:1fr auto;gap:40px;align-items:center;border-radius:24px;margin:0 5% 100px;position:relative;overflow:hidden;}
  .specials-banner::before{content:'🎉';position:absolute;right:200px;top:50%;transform:translateY(-50%);font-size:8rem;opacity:.15;}
  .specials-title{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,3vw,2.6rem);font-weight:900;color:var(--white);margin-bottom:8px;}
  .specials-desc{color:rgba(255,255,255,.85);font-size:1rem;}
  .btn-white{background:var(--white);color:var(--gold);border:none;padding:16px 36px;border-radius:50px;font-size:.9rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;cursor:pointer;white-space:nowrap;transition:transform .3s,box-shadow .3s;text-decoration:none;display:inline-block;}
  .btn-white:hover{transform:translateY(-2px);box-shadow:0 10px 30px rgba(0,0,0,.2);}

  /* ORDER */
  #order{background:var(--cream);}
  .order-container{display:grid;grid-template-columns:1fr 380px;gap:50px;align-items:start;}
  .order-form-wrap{background:var(--white);border-radius:24px;padding:50px;box-shadow:0 8px 40px var(--shadow);}
  .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:30px;}
  .form-group{display:flex;flex-direction:column;gap:8px;}
  .form-group.full{grid-column:1/-1;}
  .form-group label{font-size:.78rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--text-mid);}
  .form-group input,.form-group select,.form-group textarea{padding:14px 18px;border:1.5px solid var(--cream-dark);border-radius:12px;font-size:.9rem;font-family:'DM Sans',sans-serif;color:var(--text-dark);background:var(--cream);transition:border-color .3s;outline:none;}
  .form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--gold);}
  .form-group textarea{resize:vertical;min-height:100px;}
  .form-submit{background:linear-gradient(135deg,var(--gold),var(--gold-light));color:var(--white);border:none;width:100%;padding:18px;border-radius:12px;font-size:1rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;cursor:pointer;margin-top:24px;transition:transform .3s,box-shadow .3s;box-shadow:0 6px 20px rgba(200,149,42,.3);}
  .form-submit:hover{transform:translateY(-2px);box-shadow:0 12px 30px rgba(200,149,42,.4);}
  .free-delivery-notice{background:linear-gradient(135deg,rgba(37,211,102,.1),rgba(37,211,102,.05));border:1px solid rgba(37,211,102,.3);border-radius:12px;padding:14px 18px;margin-top:16px;display:flex;align-items:center;gap:10px;font-weight:600;color:#1a7a3a;font-size:.9rem;}

  /* CART */
  .cart-panel{background:var(--white);border-radius:24px;padding:30px;box-shadow:0 8px 40px var(--shadow);position:sticky;top:90px;}
  .cart-title{font-family:'Playfair Display',serif;font-size:1.4rem;color:var(--brown);margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;}
  .cart-empty{text-align:center;padding:40px 20px;color:var(--text-light);}
  .cart-empty-icon{font-size:3rem;margin-bottom:12px;}
  .cart-item{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--cream-dark);}
  .cart-item-thumb{width:48px;height:48px;border-radius:10px;overflow:hidden;flex-shrink:0;}
  .cart-item-thumb img{width:100%;height:100%;object-fit:cover;}
  .cart-item-thumb-emoji{width:48px;height:48px;border-radius:10px;background:var(--cream-dark);display:flex;align-items:center;justify-content:center;font-size:1.6rem;flex-shrink:0;}
  .cart-item-info{flex:1;}
  .cart-item-name{font-weight:600;font-size:.9rem;color:var(--brown);}
  .cart-item-price{font-size:.82rem;color:var(--gold);font-weight:600;}
  .cart-item-qty{display:flex;align-items:center;gap:8px;}
  .qty-btn{width:26px;height:26px;border-radius:50%;border:1.5px solid var(--cream-dark);background:transparent;cursor:pointer;font-size:.9rem;font-weight:700;display:flex;align-items:center;justify-content:center;transition:all .2s;color:var(--text-dark);}
  .qty-btn:hover{background:var(--gold);border-color:var(--gold);color:var(--white);}
  .qty-num{font-weight:700;font-size:.9rem;min-width:20px;text-align:center;}
  .cart-total{margin-top:16px;padding-top:16px;border-top:2px solid var(--cream-dark);}
  .cart-total-row{display:flex;justify-content:space-between;font-size:.85rem;color:var(--text-mid);margin-bottom:8px;}
  .cart-total-row.grand{font-family:'Playfair Display',serif;font-size:1.2rem;color:var(--brown);font-weight:700;margin-top:12px;padding-top:12px;border-top:1px solid var(--cream-dark);}
  .cart-free-delivery{background:linear-gradient(135deg,rgba(37,211,102,.1),rgba(37,211,102,.05));border:1px solid rgba(37,211,102,.3);border-radius:10px;padding:10px 14px;margin:10px 0;display:flex;align-items:center;gap:8px;font-size:.82rem;font-weight:600;color:#1a7a3a;}
  .cart-checkout{background:var(--brown);color:var(--white);border:none;width:100%;padding:15px;border-radius:12px;font-size:.9rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;cursor:pointer;margin-top:16px;transition:background .3s;}
  .cart-checkout:hover{background:var(--gold);}
  .whatsapp-order{background:#25D366;color:var(--white);border:none;width:100%;padding:13px;border-radius:12px;font-size:.85rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;cursor:pointer;margin-top:10px;display:flex;align-items:center;justify-content:center;gap:8px;transition:opacity .3s;}
  .whatsapp-order:hover{opacity:.9;}

  /* REVIEWS */
  #reviews{background:var(--cream-dark);}
  .reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:50px;}
  .review-card{background:var(--white);border-radius:20px;padding:32px;box-shadow:0 4px 20px var(--shadow);position:relative;transition:transform .3s;}
  .review-card:hover{transform:translateY(-4px);}
  .review-quote{font-size:3rem;color:var(--gold-pale);font-family:'Playfair Display',serif;line-height:1;margin-bottom:12px;display:block;}
